FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     acoFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         5;

deltaT          0.001;

writeControl    runTime;

writeInterval   2;

purgeWrite      0;

writeFormat     binary;

writePrecision  8;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{

fieldAveragePa
{
    // Mandatory entries (unmodifiable)
    type            fieldAverage;
    libs            (fieldFunctionObjects);
    writeControl    writeTime;

    timeStart         3;

    // Mandatory entries (runtime modifiable)
    fields
    (
        pa
        {
            mean        yes;
            prime2Mean  yes;
            base        time;
        }
        
    );
 
}

probeLineData
  {
    type sets;
        //libs ("libsampling.so");

//    enabled true;
//    verbose true;
    interpolationScheme cellPoint;
    writeControl timeStep;
    writeInterval 100;
    setFormat raw;
    fields (pa); 
    sets
    (
    line1
    {// line name
        type uniform;
        axis x;
        start           (   0 -36 0);
        end             (3000 -36 0);
        nPoints         600;
        }
    line2
    {// line name
        type uniform;
        axis x;
        start           (   0 -46 0);
        end             (3000 -46 0);
        nPoints         600;
        }
    );

   }

}
