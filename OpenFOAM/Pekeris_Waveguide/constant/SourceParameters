FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      SourceParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
source	true;
fr	20;                // source frequency
center  (0 -36 0);     // source location
radius 	15;            // radius of the spherical region where the source values are inposed
amp     1.414213562;   // source amplitude
//Sources
	//monopole
	monopole 	true;

	//dipole
        dipole          false;
        d               0.4; // distance between poles
        theta_          90;  // dipole oriantation - azimutal direction
        psi_            90; 

    //ricker
	ricker		false;
	t0      	0.1;

//Moving
circle	false;  // this is not used
	r 	10;     // this is not used
	frot 	20; // this is not used

line 	false;     // moving source along a line
	p1 (-50 0 0);  // start point
 	p2 ( 50 0 0);  // end point
	vel 10;        // source velocity

// ************************************************************************* //
